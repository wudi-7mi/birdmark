# Birdmark business API runtime settings.
# Copy to .env or export these variables in your shell/service manager.

BIRDMARK_API_HOST=127.0.0.1
BIRDMARK_API_PORT=8100
BIRDMARK_INFERENCE_URL=http://127.0.0.1:8000

# Relative paths are resolved from the repository root.
BIRDMARK_STORAGE_ROOT=storage
BIRDMARK_DATABASE_PATH=storage/birdmark.sqlite3

# Usually only needed when serving the web assets from another directory.
BIRDMARK_WEB_DIR=apps/web
